"""
hr analytics: анализ текучести кадров
датасет: ibm hr analytics employee attrition & performance
автор: ярослав бородин
дата: июнь 2026
"""

import kagglehub
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import os

print("загрузка данных...")

path = kagglehub.dataset_download("pavansubhasht/ibm-hr-analytics-attrition-dataset")
print(f"путь к данным: {path}")

csv_files = [f for f in os.listdir(path) if f.endswith('.csv')]
print(f"найдены csv файлы: {csv_files}")

if csv_files:
    file_path = os.path.join(path, csv_files[0])
    df = pd.read_csv(file_path)
    print(f"загружено {len(df)} строк, {len(df.columns)} колонок")
else:
    print("csv файл не найден")
    exit()

print("\nразмер данных:")
print(df.shape)

print("\nколонки:")
print(df.columns.tolist())

print("\nпервые 5 строк:")
print(df.head())

print("\nтипы данных:")
print(df.dtypes)

print("\nпропуски:")
print(df.isnull().sum())

numeric_cols = df.select_dtypes(include=[np.number]).columns
print("\nописательная статистика:")
print(df[numeric_cols].describe().round(2))

categorical_cols = df.select_dtypes(include=['object']).columns
print("\nкатегориальные колонки:")
for col in categorical_cols:
    print(f"\n{col}:")
    print(df[col].value_counts().head())

attrition_count = df['Attrition'].value_counts()
attrition_rate = (attrition_count['Yes'] / len(df)) * 100

print("\nанализ текучести:")
print(f"всего сотрудников: {len(df)}")
print(f"уволились: {attrition_count.get('Yes', 0)}")
print(f"остались: {attrition_count.get('No', 0)}")
print(f"уровень текучести: {attrition_rate:.2f}%")

dept_attrition = df.groupby('Department')['Attrition'].value_counts().unstack(fill_value=0)
dept_attrition['attrition_rate'] = (dept_attrition['Yes'] / (dept_attrition['Yes'] + dept_attrition['No'])) * 100
dept_attrition = dept_attrition.sort_values('attrition_rate', ascending=False)

print("\nтекучесть по отделам:")
print(dept_attrition)

print("\nстроим графики...")

sns.set_style("whitegrid")
plt.rcParams['figure.figsize'] = (12, 8)

fig, axes = plt.subplots(2, 2, figsize=(14, 10))
fig.suptitle('hr analytics: анализ текучести кадров', fontsize=16, fontweight='bold')

dept_attrition_sorted = dept_attrition.sort_values('attrition_rate', ascending=True)
colors = ['#ff6b6b' if rate > 20 else '#feca57' if rate > 15 else '#48dbfb' for rate in dept_attrition_sorted['attrition_rate']]
axes[0, 0].barh(dept_attrition_sorted.index, dept_attrition_sorted['attrition_rate'], color=colors)
axes[0, 0].set_title('уровень текучести по отделам', fontsize=12, fontweight='bold')
axes[0, 0].set_xlabel('уровень текучести (%)')
axes[0, 0].axvline(attrition_rate, color='red', linestyle='--', linewidth=2, label=f'средний: {attrition_rate:.1f}%')
axes[0, 0].legend()

axes[0, 1].hist(df[df['Attrition'] == 'Yes']['Age'], bins=15, alpha=0.7, label='уволились', color='#ff6b6b')
axes[0, 1].hist(df[df['Attrition'] == 'No']['Age'], bins=15, alpha=0.7, label='остались', color='#48dbfb')
axes[0, 1].set_title('распределение по возрасту', fontsize=12, fontweight='bold')
axes[0, 1].set_xlabel('возраст')
axes[0, 1].set_ylabel('количество')
axes[0, 1].legend()

job_satisfaction = df.groupby('JobSatisfaction')['Attrition'].value_counts().unstack(fill_value=0)
job_satisfaction_pct = job_satisfaction.div(job_satisfaction.sum(axis=1), axis=0) * 100
job_satisfaction_pct.plot(kind='bar', stacked=True, ax=axes[1, 0], color=['#48dbfb', '#ff6b6b'])
axes[1, 0].set_title('текучесть по уровню удовлетворённости', fontsize=12, fontweight='bold')
axes[1, 0].set_xlabel('удовлетворённость работой (1-низкая, 4-высокая)')
axes[1, 0].set_ylabel('процент')
axes[1, 0].legend(['остались', 'уволились'])

sns.boxplot(x='Attrition', y='MonthlyIncome', data=df, ax=axes[1, 1], palette=['#48dbfb', '#ff6b6b'])
axes[1, 1].set_title('распределение зарплат', fontsize=12, fontweight='bold')
axes[1, 1].set_xlabel('статус')
axes[1, 1].set_ylabel('ежемесячный доход ($)')

plt.tight_layout()
plt.savefig('hr_attrition_analysis.png', dpi=300, bbox_inches='tight')
print("график сохранён как 'hr_attrition_analysis.png'")
plt.show()

print("\nключевые наблюдения:")
print(f"""
1. общий уровень текучести: {attrition_rate:.2f}%
2. отделы с наибольшей текучестью:
{dept_attrition.head(3).to_string() if len(dept_attrition) > 0 else 'нет данных'}
3. средний возраст уволившихся: {df[df['Attrition'] == 'Yes']['Age'].mean():.0f} лет
4. средняя зарплата:
   уволившиеся: {df[df['Attrition'] == 'Yes']['MonthlyIncome'].mean():.0f} $
   оставшиеся: {df[df['Attrition'] == 'No']['MonthlyIncome'].mean():.0f} $
   разница: {(df[df['Attrition'] == 'No']['MonthlyIncome'].mean() - df[df['Attrition'] == 'Yes']['MonthlyIncome'].mean()):.0f} $
""")

print("\nсохраняем очищенные данные...")
os.makedirs('data', exist_ok=True)
df.to_csv('data/clean_hr_data.csv', index=False)
print("очищенные данные сохранены в 'data/clean_hr_data.csv'")

print("\nsql-запросы, использованные в анализе:")
sql_queries = """
-- уровень текучести по отделам
select 
    department,
    count(*) as total_employees,
    sum(case when attrition = 'Yes' then 1 else 0 end) as attrition_count,
    round(sum(case when attrition = 'Yes' then 1 else 0 end) * 100.0 / count(*), 2) as attrition_rate
from clean_hr_data
group by department
order by attrition_rate desc;

-- влияние стажа на текучесть
select 
    yearsatcompany,
    count(*) as employees,
    round(sum(case when attrition = 'Yes' then 1 else 0 end) * 100.0 / count(*), 2) as attrition_rate
from clean_hr_data
group by yearsatcompany
order by yearsatcompany;

-- связь зарплаты и текучести
select 
    case 
        when monthlyincome < 5000 then 'низкая'
        when monthlyincome < 10000 then 'средняя'
        else 'высокая'
    end as salary_level,
    count(*) as employees,
    round(sum(case when attrition = 'Yes' then 1 else 0 end) * 100.0 / count(*), 2) as attrition_rate
from clean_hr_data
group by salary_level
order by attrition_rate desc;

-- профиль уволившегося сотрудника
select 
    avg(age) as avg_age,
    avg(yearsatcompany) as avg_tenure,
    avg(monthlyincome) as avg_salary,
    gender,
    education
from clean_hr_data
where attrition = 'Yes'
group by gender, education;
"""
print(sql_queries)

print("\nанализ завершён")